{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{ENGINE_DIR}}/scripts/hooks/session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node {{ENGINE_DIR}}/scripts/hooks/check-console-log.js"
          },
          {
            "type": "command",
            "command": "node {{ENGINE_DIR}}/scripts/hooks/check-hardcoded-styles.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{ENGINE_DIR}}/scripts/hooks/session-stop.js"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": []
  }
}
